BOT_TOKEN=123456789:YOUR_BOT_TOKEN

# ID чатов-источников через запятую (без пробелов после запятой).
# Пример: -1001111111111,-1002222222222
SOURCE_CHAT_IDS=

# ID целевой группы (куда слать найденные сообщения)
TARGET_CHAT_ID=

# --- Форумы (темы внутри одной супергруппы) ---
# У форума один chat_id; у каждой «ветки» свой message_thread_id (число).
# SOURCE_TOPIC_IDS пусто = слушать все темы в SOURCE_CHAT_IDS.
# Пример (только темы 3 и 7): SOURCE_TOPIC_IDS=3,7
# SOURCE_TOPIC_IDS=
# Если цель — форум и нужна конкретная тема: ID темы куда постить копии
# TARGET_TOPIC_ID=

# Ключевые слова для поиска заказов через запятую.
# Если оставить пустым — бот будет пересылать все сообщения из SOURCE_CHAT_IDS.
ORDER_KEYWORDS=заказ,ищу,нужно,срочно,бюджет

# --- Сеть (ConnectError / TimedOut к api.telegram.org) ---
# Локальный HTTP-прокси из Clash / v2rayN / Hiddify (порт смотрите в клиенте).
# TELEGRAM_PROXY=http://127.0.0.1:7890

# Взять прокси из настроек Windows («Параметры → Сеть → Прокси»), если VPN его выставляет.
# TELEGRAM_USE_SYSTEM_PROXY=1

# Или стандартные переменные (можно вместо TELEGRAM_PROXY):
# HTTPS_PROXY=http://127.0.0.1:7890

# Таймауты в секундах (необязательно).
# TELEGRAM_CONNECT_TIMEOUT=30
# TELEGRAM_READ_TIMEOUT=30
# TELEGRAM_WRITE_TIMEOUT=30
# TELEGRAM_POOL_TIMEOUT=10

# Для socks5:// установите: pip install "python-telegram-bot[socks]"

# --- Отладка пересылки ---
# TELEGRAM_DEBUG_FILTER=1 — в лог пишется текст сообщений из SOURCE_CHAT_IDS, которые не прошли по ключевым словам
# TELEGRAM_LOG_UNKNOWN_CHAT=1 — в лог пишется chat_id любого сообщения НЕ из SOURCE_CHAT_IDS (шумно; выключайте после проверки)
